APP_NAME=نزدیک
APP_VERSION=1.0.0
DEBUG=true
ENVIRONMENT=development
LOG_LEVEL=DEBUG

HOST=0.0.0.0
PORT=8000
WORKERS=1

# SQLite برای development (نیاز به PostgreSQL نداره)
DATABASE_URL=sqlite+aiosqlite:///./nazdik_dev.db
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=5

REDIS_URL=redis://localhost:6379/0

SECRET_KEY=nazdik-super-secret-key-development-only-32chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,http://127.0.0.1:5173

MEDIA_ROOT=./media
MAX_UPLOAD_SIZE_MB=10

OTP_EXPIRE_MINUTES=5
OTP_LENGTH=6

SMS_PROVIDER=mock
SMS_API_KEY=test

TZ=Asia/Tehran
