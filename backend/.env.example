# =============================================
# تنظیمات پایه
# =============================================
APP_NAME=Nazdik
APP_VERSION=1.0.0
DEBUG=False
SECRET_KEY=change-this-to-a-very-long-random-secret-key-at-least-64-chars

# =============================================
# دیتابیس PostgreSQL
# =============================================
DATABASE_URL=postgresql+asyncpg://nazdik_user:nazdik_pass@localhost:5432/nazdik_db
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=0

# =============================================
# Redis
# =============================================
REDIS_URL=redis://localhost:6379/0
REDIS_CELERY_URL=redis://localhost:6379/1

# =============================================
# JWT
# =============================================
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
JWT_ALGORITHM=HS256

# =============================================
# SMS (لایه انتزاعی)
# =============================================
SMS_PROVIDER=kavenegar
SMS_API_KEY=your-sms-api-key
SMS_SENDER=your-sender-number

# =============================================
# ذخیره‌سازی فایل
# =============================================
MEDIA_ROOT=/var/www/nazdik/media
MEDIA_URL=/media/

# =============================================
# پرداخت
# =============================================
ZARINPAL_MERCHANT_ID=your-zarinpal-merchant-id
IDPAY_API_KEY=your-idpay-api-key

# =============================================
# CORS — دامنه‌های مجاز (کاما جدا)
# =============================================
ALLOWED_ORIGINS=http://localhost:5173,https://nazdik.ir

# =============================================
# Rate Limiting
# =============================================
OTP_REQUEST_RATE_LIMIT=3
OTP_REQUEST_RATE_WINDOW=600
OTP_VERIFY_MAX_ATTEMPTS=5
OTP_VERIFY_LOCK_SECONDS=900

# =============================================
# لاگ — تنها جایی که TZ=Asia/Tehran استفاده می‌شود
# =============================================
LOG_TZ=Asia/Tehran
LOG_LEVEL=INFO
