# تنظیمات اپلیکیشن
APP_NAME="نزدیک"
APP_VERSION="1.0.0"
DEBUG=True
ENVIRONMENT=development
LOG_LEVEL=INFO

# سرور
HOST=0.0.0.0
PORT=8080
WORKERS=4

# دیتابیس PostgreSQL
DATABASE_URL=postgresql+asyncpg://nazdik_user:nazdik_pass@localhost:5432/nazdik_db
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# Redis
REDIS_URL=redis://localhost:6379/0

# امنیت JWT
SECRET_KEY=change-this-to-a-very-long-random-string-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# فایل‌ها
MEDIA_ROOT=/var/www/nazdik/media
MAX_UPLOAD_SIZE_MB=10

# OTP
OTP_EXPIRE_MINUTES=5
OTP_LENGTH=6

# SMS (انتخاب یکی: kavenegar / melipayamak / ghasedak)
SMS_PROVIDER=kavenegar
SMS_API_KEY=your-api-key-here

# Rate Limiting
RATE_LIMIT_OTP_REQUEST=3/10minute
RATE_LIMIT_OTP_VERIFY=5/10minute
RATE_LIMIT_GENERAL=100/minute

# زمان (برای لاگ‌ها)
TZ=Asia/Tehran
